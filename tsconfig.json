{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./",
    "declaration": true,
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "node",
    "jsx": "react",
    "skipLibCheck": true,
    "paths": {
      "@@/*": [
        ".dumi/tmp/*"
      ]
    },
    "ignoreDeprecations": "5.0"
  },
  "include": [
    ".fatherrc.ts",
    "./src",
    "./tests",
    "./typings/"
  ],
  "typings": "./typings/index.d.ts",
  "exclude": [
    "node_modules",
    "build",
    "scripts",
    "acceptance-tests",
    "webpack",
    "jest",
    "src/setupTests.ts",
    "tslint:latest",
    "tslint-config-prettier"
  ]
}
