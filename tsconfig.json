{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "skipLibCheck": true,
    "paths": {
      "@@/*": ["./.dumi/tmp/*"]
    },
    "strict": false
  },
  "include": ["global.d.ts", ".fatherrc.ts", "./src", "./tests", "./typings/"],
  "typings": "./typings/index.d.ts",
  "exclude": [
    "node_modules",
    "build",
    "scripts",
    "acceptance-tests",
    "webpack",
    "jest",
    "src/setupTests.ts",
    "tslint:latest",
    "tslint-config-prettier"
  ]
}
